APP_NAME=Clinical Trials Hybrid Agent
APP_ENV=development
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=pretty
DATA_DIR=./data
DEFAULT_TOP_K=8
CHUNK_SIZE=1100
CHUNK_OVERLAP=160
MAX_ANSWER_CITATIONS=8
MAX_ANSWER_CONTEXT_CHUNKS=8
MAX_ANSWER_CONTEXT_CHARS=1800
MAX_UPLOAD_MB=15
MAX_REMOTE_FILE_MB=25
MAX_MANIFEST_ITEMS=20
ALLOWED_LOCAL_ROOTS=./data,.
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=45
SEMANTIC_RETRIEVAL_ENABLED=true
EMBEDDING_BATCH_SIZE=24
AUTO_BOOTSTRAP_SAMPLE_DATA=true
